{
  "name": "@pantrymaid/server",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bun build src/index.ts --outdir=dist --target=bun",
    "start": "bun run dist/index.js",
    "lint": "eslint src/ --ext .ts",
    "test": "echo 'No server tests yet' && exit 0",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "seed": "bun run src/db/seed.ts"
  },
  "dependencies": {
    "@pantrymaid/shared": "workspace:*",
    "better-auth": "^1.5.6",
    "drizzle-orm": "^0.38.0",
    "hono": "^4.0.0",
    "postgres": "^3.4.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bun": "^1.0.0",
    "drizzle-kit": "^0.31.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  }
}

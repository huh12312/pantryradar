# Database
POSTGRES_DB=pantrymaid
POSTGRES_USER=pantrymaid
POSTGRES_PASSWORD=changeme_secure_password_here
# For production, add ?sslmode=require to enable encrypted connections
DATABASE_URL=postgresql://pantrymaid:changeme_secure_password_here@postgres:5432/pantrymaid

# Auth
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be at least 32 characters for security
BETTER_AUTH_SECRET=changeme_random_32_byte_base64_secret_EXAMPLE_vJ8fK2mN9pQ3rS5tU7vW9yZ1aB3cD5eF
BETTER_AUTH_URL=https://localhost:3000

# LLM provider — one of: openai, anthropic, groq, ollama (default: openai)
LLM_PROVIDER=openai
# Override the default model for the selected provider (optional)
# Defaults: openai=gpt-4o-mini, anthropic=claude-haiku-4-5-20251001, groq=llama-3.1-8b-instant, ollama=llama3.2
# LLM_MODEL=gpt-4o-mini
# Vision model used for receipt image parsing (requires vision capability)
# Defaults: openai=gpt-5.4-mini, anthropic=claude-sonnet-4-6
# Only openai and anthropic providers support vision
# LLM_VISION_MODEL=gpt-5.4-mini

# OpenAI (required when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic (required when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Groq (required when LLM_PROVIDER=groq)
# Free tier at https://console.groq.com
# GROQ_API_KEY=gsk_your-groq-key-here

# Ollama (required when LLM_PROVIDER=ollama — no API key needed)
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Pexels (image fallback for items not in Open Food Facts or Wikipedia seed)
# Free at https://www.pexels.com/api/ — 200 req/hour, 20k req/month
PEXELS_API_KEY=your_pexels_api_key_here

# Kroger Public API (https://developer.kroger.com)
# Required for primary grocery product lookup (Kroger → Open Food Facts fallback chain)
# Covers Kroger-banner stores; Harris Teeter items not included (separate HT pipeline)
KROGER_CLIENT_ID=your_kroger_client_id
KROGER_CLIENT_SECRET=your_kroger_client_secret

# Feature flags
# Set to "false" to disable new user registration (existing users can still log in)
SIGNUP_ENABLED=true

# Server
PORT=3000
NODE_ENV=production

# Caddy
DOMAIN=localhost
SSL_MODE=internal

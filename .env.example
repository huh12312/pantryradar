# Database
POSTGRES_DB=pantrymaid
POSTGRES_USER=pantrymaid
POSTGRES_PASSWORD=changeme_secure_password_here
# For production, add ?sslmode=require to enable encrypted connections
DATABASE_URL=postgresql://pantrymaid:changeme_secure_password_here@postgres:5432/pantrymaid

# Auth
# Generate with: openssl rand -base64 32
# IMPORTANT: Must be at least 32 characters for security
BETTER_AUTH_SECRET=changeme_random_32_byte_base64_secret_EXAMPLE_vJ8fK2mN9pQ3rS5tU7vW9yZ1aB3cD5eF
BETTER_AUTH_URL=https://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Pexels (image fallback for items not in Open Food Facts or Wikipedia seed)
# Free at https://www.pexels.com/api/ — 200 req/hour, 20k req/month
PEXELS_API_KEY=your_pexels_api_key_here

# Veryfi
VERYFI_CLIENT_ID=your_veryfi_client_id
VERYFI_CLIENT_SECRET=your_veryfi_client_secret
VERYFI_USERNAME=your_veryfi_username
VERYFI_API_KEY=your_veryfi_api_key

# Server
PORT=3000
NODE_ENV=production

# Caddy
DOMAIN=localhost
SSL_MODE=internal

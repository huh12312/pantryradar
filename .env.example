# Database
POSTGRES_DB=pantrymaid
POSTGRES_USER=pantrymaid
POSTGRES_PASSWORD=changeme_secure_password_here
DATABASE_URL=postgresql://pantrymaid:changeme_secure_password_here@postgres:5432/pantrymaid

# Auth
BETTER_AUTH_SECRET=changeme_random_32_byte_base64_secret
BETTER_AUTH_URL=https://localhost:3000

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key-here

# Veryfi
VERYFI_CLIENT_ID=your_veryfi_client_id
VERYFI_CLIENT_SECRET=your_veryfi_client_secret
VERYFI_USERNAME=your_veryfi_username
VERYFI_API_KEY=your_veryfi_api_key

# Server
PORT=3000
NODE_ENV=production

# Caddy
DOMAIN=localhost
SSL_MODE=internal

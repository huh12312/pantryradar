        {
          "name": "households",
          "key": "id (uuid)",
          "fields": ["name", "inviteCode (unique)", "createdAt"]
        },
        {
          "name": "users",
          "key": "id (text → user.id)",
          "fields": ["householdId", "displayName", "createdAt"]
        },
        {
          "name": "items",
          "key": "id (uuid)",
          "fields": [
            "householdId",
            "name",
            "brand",
            "category",
            "location ∈ {pantry,fridge,freezer}",
            "quantity",
            "unit",
            "barcodeUpc",
            "imageUrl",
            "expirationDate",
            "expirationEstimated",
            "addedBy",
            "addedAt",
            "updatedAt",
            "notes"
